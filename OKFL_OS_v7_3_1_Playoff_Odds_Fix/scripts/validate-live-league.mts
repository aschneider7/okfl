import assert from "node:assert/strict";
import {buildLeagueDashboard,simulatePlayoffOdds} from "../lib/liveLeague.ts";
import {buildAwardsRace} from "../lib/leagueAwards.ts";

const franchises=Array.from({length:10},(_,index)=>({id:`F${String(index+1).padStart(2,"0")}`,name:`Team ${index+1}`,display_name:`Team ${index+1}`,current_manager:`Manager ${index+1}`,original_manager:`Manager ${index+1}`}));
const power=franchises.map((team,index)=>({rank:index+1,franchiseId:team.id,franchise:team.name,manager:team.current_manager,score:90-index*5,tier:"Contender",movement:0,previousRank:index+1,record:"0-0",dimensions:[],strength:{key:"power",label:"Power",score:90-index*5,weight:100,detail:"Test"},concern:{key:"power",label:"Power",score:90-index*5,weight:100,detail:"Test"},summary:"Test"}));
const rosters=franchises.map((team,index)=>({roster_id:index+1,franchise_id:team.id,franchise:team.name,players:[`P${index+1}`],settings:{wins:index<5?1:0,losses:index<5?0:1,fpts:120-index,fpts_decimal:0}}));
const matchups=[...Array.from({length:5},(_,index)=>[{week:1,matchup_id:index+1,franchise_id:franchises[index].id,points:120-index,players_points:{[`P${index+1}`]:30-index}},{week:1,matchup_id:index+1,franchise_id:franchises[9-index].id,points:100-index,players_points:{[`P${10-index}`]:20-index}}]).flat(),...Array.from({length:5},(_,index)=>[{week:2,matchup_id:index+1,franchise_id:franchises[index].id,points:0},{week:2,matchup_id:index+1,franchise_id:franchises[9-index].id,points:0}]).flat()];
const snapshot={synced_at:new Date().toISOString(),rosters,matchups,trades:[],transactions:[{status:"complete",type:"waiver",roster_ids:[1],adds:[{player_id:"P1"}]}]};
const dashboard=buildLeagueDashboard(snapshot,power,franchises);
assert.equal(dashboard.standings.length,10);
assert.equal(dashboard.completedWeek,1);
assert.equal(dashboard.currentWeek,2);
assert.equal(dashboard.matchups.length,10);
const odds=simulatePlayoffOdds(dashboard,1000);
assert.equal(odds.length,10);
assert.ok(Math.abs(odds.reduce((sum,team)=>sum+team.playoff,0)-600)<0.01,"Six playoff berths must be awarded in every simulation.");
assert.ok(Math.abs(odds.reduce((sum,team)=>sum+team.champion,0)-100)<0.01,"Every simulation must produce one champion.");
assert.ok(Math.abs(odds.reduce((sum,team)=>sum+team.projectedWins,0)-70)<0.01,"The simulator must fill every missing regular-season matchup through Week 14.");
assert.ok(odds.every((team)=>team.playoff>=0&&team.playoff<=100&&team.champion>=0&&team.champion<=100));
const preseasonSnapshot={...snapshot,rosters:rosters.map((roster)=>({...roster,settings:{wins:0,losses:0,ties:0,fpts:0,fpts_decimal:0}})),matchups:[]};
const preseasonDashboard=buildLeagueDashboard(preseasonSnapshot,power,franchises);
const preseasonOdds=simulatePlayoffOdds(preseasonDashboard,5000);
assert.ok(preseasonOdds.every((team)=>team.playoff>10&&team.playoff<95),"Preseason playoff odds must preserve meaningful uncertainty.");
assert.ok(preseasonOdds.every((team)=>team.projectedWins>=4.5&&team.projectedWins<=9.5),"Preseason projected records must remain within a realistic range.");
const liveWeekDashboard=buildLeagueDashboard({...preseasonSnapshot,nfl_state:{week:1},matchups:matchups.slice(0,10)},power,franchises);
assert.equal(liveWeekDashboard.completedWeek,0,"An in-progress scoring week must not be treated as final.");
const directory=Object.fromEntries(franchises.map((_,index)=>[`P${index+1}`,{full_name:`Player ${String.fromCharCode(65+index)}`,position:index<3?"QB":"WR",team:"TST"}]));
const awards=buildAwardsRace(snapshot,directory,power,dashboard);
assert.equal(awards.playerRaces.length,4);
assert.equal(awards.managerRaces.length,2);
assert.equal(awards.weeklyLeaders["1"].length,5);
assert.equal(awards.playerRaces[0].candidates[0].name,"Player A");
console.log({live_teams:dashboard.standings.length,simulations:1000,playoff_slots:6,award_races:awards.playerRaces.length+awards.managerRaces.length});
